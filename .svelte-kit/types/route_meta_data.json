{
	"/(app)": [
		"src/routes/(app)/+layout.ts"
	],
	"/": [
		"src/routes/+page.ts"
	],
	"/api/sessions": [
		"src/routes/api/sessions/+server.ts"
	],
	"/api/sessions/new": [
		"src/routes/api/sessions/new/+server.ts"
	],
	"/api/sessions/[id]": [
		"src/routes/api/sessions/[id]/+server.ts"
	],
	"/(app)/display": [
		"src/routes/(app)/display/+page.server.ts",
		"src/routes/(app)/+layout.ts"
	],
	"/(app)/mobile": [
		"src/routes/(app)/mobile/+page.server.ts",
		"src/routes/(app)/+layout.ts"
	]
}